{
  "name": "Read Manga Filters",
  "description": "Read Manga Filters",
  "version": "1.0",
  "manifest_version": 3,
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icons/icon-128.png"
  },
  "content_scripts": [
    {
      "js": ["js/inject.js"],
      "matches": [
        "https://*.zazaza.me/list/*",
        "https://zazaza.me/list/*",
        "https://*.seimanga.me/list/*",
        "https://seimanga.me/list/*"
      ]
    }
  ],
  "background": {
    "service_worker": "js/background.js"
  },
  "permissions": ["scripting", "webRequest", "storage"],
  "host_permissions": [
    "https://*.seimanga.me/list/*",
    "https://seimanga.me/list/*",
    "https://*.zazaza.me/list/*",
    "https://zazaza.me/list/*",
    "https://api.rmr.rocks/api/bookmark/getAllList"
  ]
}
